# AWS Configuration (インフラ設定情報)
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=PlaywrightOutput

# AWS Credentials (シークレット情報)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# 注意: 他の設定値（NODE_ENV, BROWSER_HEADLESS, PAGE_TIMEOUTなど）は
# src/config/nonsecret_const.ts に定義されており、
# 必要に応じて環境変数で上書きできます
