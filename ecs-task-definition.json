{
  "family": "playwright-cloud-executer",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "taskRoleArn": "arn:aws:iam::442426886752:role/Playwright-ExecutionRole",
  "executionRoleArn": "arn:aws:iam::442426886752:role/Playwright-ExecutionRole",
  "containerDefinitions": [
    {
      "name": "playwright-container",
      "image": "442426886752.dkr.ecr.ap-northeast-1.amazonaws.com/playwright-cloud-executer:latest",
      "essential": true,
      "memory": 1024,
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "SITE_NAME",
          "value": "yahoo"
        },
        {
          "name": "BROWSER_HEADLESS",
          "value": "true"
        },
        {
          "name": "PAGE_TIMEOUT",
          "value": "30000"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/playwright-cloud-executer",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Project",
      "value": "PlaywrightCloudExecuter"
    }
  ]
}
